@model AymanFreelance.PL.Models.FreelancerDashboardVM

@{
    ViewData["Title"] = "Freelancer Panel";
}

<div class="container mt-4">
    <h2 class="mb-4">Freelancer Dashboard</h2>

    <div class="row">
        <!-- Profile Section -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">

                    @if (string.IsNullOrEmpty(Model.Photo))
                        Model.Photo = "FreelancerEmpty.png";

                    <img class="rounded-circle mb-3" width="120" height="120"
                         src="~/Images/Freelancer/@Model.Photo"
                         alt="@Model.Name" />



                    <h5>@Model.Name</h5>
                    <p class="text-muted">@Model.Email</p>

                    <a asp-action="EditProfile" asp-controller="Freelancer" class="btn btn-primary btn-sm mt-2">
                        Edit Profile
                    </a>
                </div>
            </div>
        </div>

        <!-- Projects Section -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Current Projects</h5>
                </div>
                <div class="card-body">
                    @if (Model.ProjectTBL_VM != null && Model.ProjectTBL_VM.Any())
                    {
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Status</th>
                                    <th>Deadline</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in Model.ProjectTBL_VM)
                                {
                                    <tr>
                                        <td>@project.Name</td>
                                        <td>
                                            <span class="badge bg-success">
                                                @(project.DateOfDelivery != null && project.DateOfDelivery < DateTime.Now ? "Delivered ✅" : "In Progress ⏳")
                                            </span>
                                        </td>
                                        <td>@project.DateOfDelivery.Value.ToString("dd MMM yyyy hh:mm tt")</td>
                                        <td>
                                            <a asp-action="WhoisProject" asp-controller="Home" asp-route-id="@project.ID" class="btn btn-sm btn-outline-primary">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No projects assigned yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

