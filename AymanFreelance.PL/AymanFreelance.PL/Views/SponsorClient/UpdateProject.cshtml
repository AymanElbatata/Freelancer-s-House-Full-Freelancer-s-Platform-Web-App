@model AymanFreelance.PL.Models.ProjectTBL_VM

@{
    ViewData["Title"] = "Update Project";
}

@if (Model?.Errors != null && Model.Errors.Any())
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var errorGroup in Model.Errors)
            {
                foreach (var msg in errorGroup.Value)
                {
                    <li>@msg</li>
                }
            }
        </ul>
    </div>
}

@if (Model != null)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 rounded-3">
                    <div class="card-header bg-primary text-white text-center rounded-top">
                        <h3 class="mb-0">Update Project</h3>
                    </div>
                    <div class="card-body p-5">
                        <!-- Validation Summary -->
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <form asp-controller="SponsorClient" asp-action="UpdateProject" method="post" enctype="multipart/form-data">

                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(model => model.ID)

                            <!-- Current Project Image Display -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Current Project Image</label>
                                <div class="border rounded p-3 bg-light text-center">
                                    @{
                                        var imageName = string.IsNullOrEmpty(Model.Image) ? "ProjectEmpty.jpg" : Model.Image;
                                        var imagePath = Url.Content($"~/Images/Project/{imageName}");
                                    }
                                    <img src="@imagePath"
                                         alt="Project Image"
                                         class="img-fluid rounded"
                                         style="max-height: 200px; object-fit: contain;"
                                         onerror="this.onerror=null; this.src='@Url.Content("~/Images/Project/ProjectEmpty.jpg")';" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Change Project Image (Optional)</label>
                                <input type="file"
                                       name="ProjectImage"
                                       class="form-control"
                                       accept="image/*" />
                                <small class="text-muted">Leave empty to keep current image. Allowed formats: JPG, PNG, WEBP, JPEG</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control" placeholder="Enter project name" required />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label fw-bold"></label>
                                <textarea asp-for="Description" rows="4" class="form-control" placeholder="Enter project description" required></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="RequiredDaysOfDelivery" class="form-label fw-bold"></label>
                                    <input asp-for="RequiredDaysOfDelivery" type="number" class="form-control" placeholder="Delivery days" required />
                                    <span asp-validation-for="RequiredDaysOfDelivery" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="TotalCost" class="form-label fw-bold"></label>
                                    <input asp-for="TotalCost" type="number" class="form-control" placeholder="Total cost in USD" required />
                                    <span asp-validation-for="TotalCost" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="PaymentInAdvance" class="form-label fw-bold"></label>
                                <input asp-for="PaymentInAdvance" type="number" class="form-control" placeholder="Advance payment in USD" required />
                                <span asp-validation-for="PaymentInAdvance" class="text-danger"></span>
                            </div>

                            <div class="d-flex justify-content-between mt-4">
                                <a asp-controller="SponsorClient" asp-action="Projects" class="btn btn-outline-secondary px-4 rounded-pill">
                                    ⬅ Back
                                </a>
                                <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm">
                                    💾 Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <h2 class="text-center mb-5">There is no more project!...</h2>
}
